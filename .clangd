CompileFlags:
  BuiltinHeaders: QueryDriver
Diagnostics:
  Suppress: [pp_expects_filename, unused-includes]
---
If:
  PathMatch: .*\.ino
CompileFlags:
  Add:
    - "-x"
    - "c++"
    - "-include"
    - "Arduino.h"
---
# clangd uses Clang, not Xtensa GCC — drop GCC-only ESP32 flags so diagnostics match.
CompileFlags:
  Remove:
    - -mlongcalls
    - -mdisable-hardware-atomics
    - -fstrict-volatile-bitfields
    - -fno-tree-switch-conversion
