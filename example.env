# Copy or rename this file to .env (gitignored). Standard dotenv syntax.
# https://github.com/motdotla/dotenv#rules

WIFI_SSID=your_network_name
WIFI_PASSWORD=your_password
# Reserved if you add NTP / local time later (not used by current firmware).
WIFI_GMT_OFFSET_SEC=0

# UUID (or value) sent as X-Device-ID to colorink-app — required for every PlatformIO env build.
COLORINK_DEVICE_ID=00000000-0000-0000-0000-000000000000
